[Unit]
Description=Netweb G48C210R Platform Monitoring FAN service
Before=pmon.service
After=g48c210r-platform-monitor.service
DefaultDependencies=no

[Service]
ExecStart=/usr/local/bin/netweb_g48c210r_monitor_fan.py
KillSignal=SIGKILL
SuccessExitStatus=SIGKILL

# Resource Limitations
LimitCORE=infinity

[Install]
WantedBy=multi-user.target
