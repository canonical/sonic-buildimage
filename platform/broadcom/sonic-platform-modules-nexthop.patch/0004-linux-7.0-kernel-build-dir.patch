Index: sonic-platform-modules-nexthop/debian/rules
===================================================================
--- sonic-platform-modules-nexthop.orig/debian/rules
+++ sonic-platform-modules-nexthop/debian/rules
@@ -6,7 +6,12 @@ export INSTALL_MOD_DIR := extra
 
 export KVERSION   ?= $(shell uname -r)
 export KERNEL_SRC ?= /lib/modules/$(KVERSION)
-KERNEL_BUILD := $(KERNEL_SRC)/build
+# Resolute linux-sonic: /lib/modules/$(KVERSION)/build is a symlink created by
+# saibcm-modules and may not exist when this package builds standalone. The real
+# kbuild tree is the linux-headers tree, so point kbuild at it directly.
+# KERNEL_SRC (=/lib/modules/$(KVERSION)) is still used as the module install
+# path and for KBUILD_EXTRA_SYMBOLS (Module.symvers.PDDF), so it is unchanged.
+KERNEL_BUILD := /usr/src/linux-headers-$(KVERSION)
 MOD_SRC_DIR := $(shell pwd)
 MODULE_DIRS :=
 
