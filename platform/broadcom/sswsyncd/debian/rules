#!/usr/bin/make -f

%:
	dh $@

# resolute dpkg-buildflags adds C-only flags (-std=gnu17,
# -Werror=implicit-function-declaration) to CFLAGS; sswsyncd builds C++ via
# CFLAGS with -Werror, so these turn fatal. Strip them (via the environment so
# the Makefile's own -std=c++11 still applies).
override_dh_auto_build:
	CFLAGS="$(filter-out -std=gnu17 -Werror=implicit-function-declaration,$(CFLAGS))" dh_auto_build
