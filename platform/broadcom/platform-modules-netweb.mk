# Netweb Platform modules

NETWEB_F48C810R_PLATFORM_MODULE_VERSION = 1.1
NETWEB_G48C210R_PLATFORM_MODULE_VERSION = 1.1

export NETWEB_F48C810R_PLATFORM_MODULE_VERSION
export NETWEB_G48C210R_PLATFORM_MODULE_VERSION

NETWEB_F48C810R_PLATFORM_MODULE = sonic-platform-netweb-f48c810r_$(NETWEB_F48C810R_PLATFORM_MODULE_VERSION)_amd64.deb
$(NETWEB_F48C810R_PLATFORM_MODULE)_SRC_PATH = $(PLATFORM_PATH)/sonic-platform-modules-netweb
$(NETWEB_F48C810R_PLATFORM_MODULE)_DEPENDS += $(LINUX_HEADERS) $(LINUX_HEADERS_COMMON) $(PDDF_PLATFORM_MODULE_SYM)
$(NETWEB_F48C810R_PLATFORM_MODULE)_PLATFORM = x86_64-netweb_tyrone_f48c810r-r0
SONIC_DPKG_DEBS += $(NETWEB_F48C810R_PLATFORM_MODULE)

NETWEB_G48C210R_PLATFORM_MODULE = sonic-platform-netweb-g48c210r_$(NETWEB_G48C210R_PLATFORM_MODULE_VERSION)_amd64.deb
$(NETWEB_G48C210R_PLATFORM_MODULE)_PLATFORM = x86_64-netweb_tyrone_g48c210r-r0
$(eval $(call add_extra_package,$(NETWEB_F48C810R_PLATFORM_MODULE),$(NETWEB_G48C210R_PLATFORM_MODULE)))


