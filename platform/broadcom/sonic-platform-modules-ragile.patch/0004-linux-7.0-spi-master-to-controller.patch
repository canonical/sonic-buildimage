+        pr_info("register %u bus_num spi 93xx46 eeprom success\n",
             eeprom_93xx46_info.bus_num);
     }
 
@@ -94,13 +88,12 @@ static int __init wb_spi_93xx46_init(voi
 
 static void __exit wb_spi_93xx46_exit(void)
 {
-    spi_unregister_device(g_spi_device);
-
+    /* Board-info-registered devices are owned by the SPI core and are
+     * removed when the controller goes away, so there is no handle to
+     * unregister here. */
     if (g_wb_spi_93xx46_debug) {
-        dev_info(&g_spi_device->dev, "unregister spi 93xx46 eeprom success\n");
+        pr_info("unregister spi 93xx46 eeprom success\n");
     }
-
-    return;
 }
 
 module_init(wb_spi_93xx46_init);
