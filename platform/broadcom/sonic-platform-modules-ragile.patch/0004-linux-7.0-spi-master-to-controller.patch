--- sonic-platform-modules-ragile.orig/common/modules/wb_spi_93xx46.c
+++ sonic-platform-modules-ragile/common/modules/wb_spi_93xx46.c
@@ -60,32 +60,26 @@ struct spi_board_info eeprom_93xx46_info
         .platform_data      = &eeprom_data,
 };
 
-static struct spi_device *g_spi_device;
-
 static int __init wb_spi_93xx46_init(void)
 {
-    struct spi_master *master;
+    int ret;
 
     SPI_93xx46_DEBUG_VERBOSE("Enter.\n");
 
     eeprom_93xx46_info.bus_num = spi_bus_num;
     eeprom_93xx46_info.controller_data = (void *)(long)spi_cs_gpio;
-    master = spi_busnum_to_master(eeprom_93xx46_info.bus_num);
-    if (!master) {
-        SPI_93xx46_DEBUG_ERROR("get bus_num %u spi master failed.\n",
-            eeprom_93xx46_info.bus_num);
-        return -EINVAL;
-    }
-
-    g_spi_device = spi_new_device(master, &eeprom_93xx46_info);
-    put_device(&master->dev);
-    if (!g_spi_device) {
-        SPI_93xx46_DEBUG_ERROR("register spi new device failed.\n");
-        return -EPERM;
+    /* spi_busnum_to_master() was removed in Linux 7.0; register the board
+     * info so the SPI core creates the device when the matching controller
+     * (by bus_num) is present. */
+    ret = spi_register_board_info(&eeprom_93xx46_info, 1);
+    if (ret) {
+        SPI_93xx46_DEBUG_ERROR("register spi 93xx46 board info failed, ret:%d.\n",
+            ret);
+        return ret;
     }
 
     if (g_wb_spi_93xx46_debug) {
