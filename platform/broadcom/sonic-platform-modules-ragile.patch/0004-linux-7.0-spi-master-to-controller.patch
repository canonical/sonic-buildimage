Index: sonic-platform-modules-ragile/common/modules/spi-bitbang-txrx.h
===================================================================
--- sonic-platform-modules-ragile.orig/common/modules/spi-bitbang-txrx.h
+++ sonic-platform-modules-ragile/common/modules/spi-bitbang-txrx.h
@@ -54,7 +54,7 @@ bitbang_txrx_be_cpha0(struct spi_device
 	for (word <<= (32 - bits); likely(bits); bits--) {
 
 		/* setup MSB (to slave) on trailing edge */
-		if ((flags & SPI_MASTER_NO_TX) == 0) {
+		if ((flags & SPI_CONTROLLER_NO_TX) == 0) {
 			if ((word & (1 << 31)) != oldbit) {
 				setmosi(spi, word & (1 << 31));
 				oldbit = word & (1 << 31);
@@ -67,7 +67,7 @@ bitbang_txrx_be_cpha0(struct spi_device
 
 		/* sample MSB (from slave) on leading edge */
 		word <<= 1;
-		if ((flags & SPI_MASTER_NO_RX) == 0)
+		if ((flags & SPI_CONTROLLER_NO_RX) == 0)
 			word |= getmiso(spi);
 		setsck(spi, cpol);
 	}
@@ -87,7 +87,7 @@ bitbang_txrx_be_cpha1(struct spi_device
 
 		/* setup MSB (to slave) on leading edge */
 		setsck(spi, !cpol);
-		if ((flags & SPI_MASTER_NO_TX) == 0) {
+		if ((flags & SPI_CONTROLLER_NO_TX) == 0) {
 			if ((word & (1 << 31)) != oldbit) {
 				setmosi(spi, word & (1 << 31));
 				oldbit = word & (1 << 31);
@@ -100,7 +100,7 @@ bitbang_txrx_be_cpha1(struct spi_device
 
 		/* sample MSB (from slave) on trailing edge */
 		word <<= 1;
-		if ((flags & SPI_MASTER_NO_RX) == 0)
+		if ((flags & SPI_CONTROLLER_NO_RX) == 0)
 			word |= getmiso(spi);
 	}
 	return word;
Index: sonic-platform-modules-ragile/common/modules/wb_spi_93xx46.c
