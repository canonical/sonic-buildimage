
MPATH       := $($(NETWEB_F48C810R_PLATFORM_MODULE)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) platform/broadcom/platform-modules-netweb.mk platform/broadcom/platform-modules-netweb.dep   
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
DEP_FILES   += $(shell git ls-files $(MPATH))

$(NETWEB_F48C810R_PLATFORM_MODULE)_CACHE_MODE  := GIT_CONTENT_SHA 
$(NETWEB_F48C810R_PLATFORM_MODULE)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(NETWEB_F48C810R_PLATFORM_MODULE)_DEP_FILES   := $(DEP_FILES)

