job_queue: sonic-ci
provision_data:
  distro: jammy
test_data:
  test_cmds: |
    set -e
    set -x

    # 1. Install necessary packages
    ssh ubuntu@$DEVICE_IP curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /tmp/docker.gpg > /dev/null
    ssh ubuntu@$DEVICE_IP sudo apt-key add /tmp/docker.gpg
    ssh ubuntu@$DEVICE_IP 'echo "deb [arch=amd64] https://download.docker.com/linux/ubuntu jammy stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null'
    ssh ubuntu@$DEVICE_IP sudo apt update > /dev/null
    ssh ubuntu@$DEVICE_IP sudo apt remove -y containerd > /dev/null
    ssh ubuntu@$DEVICE_IP sudo apt install -y docker-ce python3 python-is-python3 python3-pip pipx curl j2cli make apt-transport-https ca-certificates gnupg-agent software-properties-common > /dev/null
    ssh ubuntu@$DEVICE_IP sudo gpasswd -a ubuntu docker
    ssh ubuntu@$DEVICE_IP sudo systemctl restart docker
    ssh ubuntu@$DEVICE_IP sudo chmod a+rw /var/run/docker.sock

    ssh ubuntu@$DEVICE_IP pip3 install -q --user j2cli > /dev/null
    ssh ubuntu@$DEVICE_IP pip3 install -q --user jinjanator > /dev/null

    # 2. Build vs image
    ssh ubuntu@$DEVICE_IP git clone -q -b {{ branch }} --recurse-submodules https://github.com/canonical/sonic-buildimage.git > /dev/null
    ssh ubuntu@$DEVICE_IP sudo modprobe overlay
    ssh ubuntu@$DEVICE_IP "cd /home/ubuntu/sonic-buildimage && make init"
    ssh ubuntu@$DEVICE_IP "cd /home/ubuntu/sonic-buildimage && MIRROR_SECURITY_URLS=http://mirror.csclub.uwaterloo.ca/ubuntu/ MIRROR_URLS=http://mirror.csclub.uwaterloo.ca/ubuntu/ make configure PLATFORM=vs"
    ssh ubuntu@$DEVICE_IP "cd /home/ubuntu/sonic-buildimage && DBGOPT=1 SONIC_BUILD_RETRY_COUNT=15 make SONIC_BUILD_JOBS=4 target/sonic-vs.img.gz"

    # 3. Prepare all images
    git clone -b sonic_on_ubuntu https://github.com/jy5275/sonic-mgmt > /dev/null
    ssh ubuntu@$DEVICE_IP git clone -b sonic_on_ubuntu https://github.com/jy5275/sonic-mgmt > /dev/null
    ssh ubuntu@$DEVICE_IP "cd sonic-mgmt/ansible && sudo -H ./setup-management-network.sh"
    ssh ubuntu@$DEVICE_IP pipx install gdown > /dev/null
    ssh ubuntu@$DEVICE_IP mkdir -p /home/ubuntu/veos-vm/images /home/ubuntu/sonic-vm/images
    ssh ubuntu@$DEVICE_IP cp /home/ubuntu/sonic-buildimage/target/sonic-vs.img.gz /home/ubuntu/veos-vm/images/sonic-vs.img.gz
    ssh ubuntu@$DEVICE_IP /home/ubuntu/.local/bin/gdown -O /home/ubuntu/veos-vm/images/cEOS64-lab-4.32.5M.tar.xz https://drive.google.com/uc?id=1SueSaAOeS3YJYiaZQ6KTXOGLR7dUQ0mb > /dev/null
    ssh ubuntu@$DEVICE_IP xz -d /home/ubuntu/veos-vm/images/cEOS64-lab-4.32.5M.tar.xz > /dev/null
    ssh ubuntu@$DEVICE_IP gzip -d /home/ubuntu/veos-vm/images/sonic-vs.img.gz > /dev/null
    ssh ubuntu@$DEVICE_IP cp /home/ubuntu/veos-vm/images/sonic-vs.img /home/ubuntu/sonic-vm/images/sonic-vs.img

    # 4. Setup mgmt container
    ssh ubuntu@$DEVICE_IP "cd sonic-mgmt && ./setup-container.sh -n mgmt -d /data"
    export MGMT_IP=$(ssh ubuntu@$DEVICE_IP docker inspect mgmt | jq -r '.[0].NetworkSettings.IPAddress')
    export HOST_IP=$(ssh ubuntu@$DEVICE_IP docker inspect mgmt | jq -r '.[0].NetworkSettings.Gateway')
    ssh ubuntu@$DEVICE_IP 'echo "ubuntu ALL=(ALL) NOPASSWD:ALL" | sudo tee -a /etc/sudoers > /dev/null'

    # 5. Deploy
    ssh ubuntu@$DEVICE_IP docker exec -w /data/sonic-mgmt/ansible mgmt ./testbed-cli.sh -t vtestbed.yaml -m veos_vtb -k ceos add-topo vms-kvm-t0 password.txt
    ssh ubuntu@$DEVICE_IP docker exec -w /data/sonic-mgmt/ansible mgmt ./testbed-cli.sh -t vtestbed.yaml -m veos_vtb deploy-mg vms-kvm-t0 veos_vtb password.txt
    # ssh ubuntu@$DEVICE_IP docker exec -w /data/sonic-mgmt/tests mgmt ./run_tests.sh -n vms-kvm-t0 -d vlab-01 -c bgp/test_bgp_fact.py -f vtestbed.yaml -i ../ansible/veos_vtb
    
    # 6. Run
    docker_exec_string="docker exec -w /data/sonic-mgmt/tests mgmt ./run_tests.sh -q 1 -n vms-kvm-t0 -d vlab-01 -f vtestbed.yaml -i ../ansible/veos_vtb"
    while read -r line; do
        docker_exec_string+=" -c $(echo $line)"
    done < sonic-mgmt/tests/cases-vs-t0.txt
    echo $docker_exec_string
    ssh ubuntu@$DEVICE_IP $docker_exec_string

output_timeout: 1800  # 30min
global_timeout: 86400 # 24hours
