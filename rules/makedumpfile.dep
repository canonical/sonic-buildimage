# resolute: makedumpfile is an ONLINE_DEB with no in-repo source to hash, so no SPATH / git ls-files.

$(MAKEDUMPFILE)_CACHE_MODE := GIT_CONTENT_SHA
$(MAKEDUMPFILE)_DEP_FLAGS  := $(SONIC_COMMON_FLAGS_LIST)
$(MAKEDUMPFILE)_DEP_FILES  := $(SONIC_COMMON_FILES_LIST) rules/makedumpfile.mk rules/makedumpfile.dep $(SONIC_COMMON_BASE_FILES_LIST)
