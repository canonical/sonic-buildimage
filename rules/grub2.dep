SPATH       := $($(GRUB2_COMMON)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) rules/grub2.mk rules/grub2.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
# resolute: grub2 is fetched via SONIC_ONLINE_DEBS, so its _SRC_PATH (SPATH) is
# empty; guard ls-files so empty SPATH does not list the whole repo (which pulls
# in device symlinks + submodule gitlinks that break the .dep git hash-object).
DEP_FILES   += $(if $(strip $(SPATH)),$(shell git ls-files $(SPATH)))

$(GRUB2_COMMON)_CACHE_MODE  := GIT_CONTENT_SHA 
$(GRUB2_COMMON)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(GRUB2_COMMON)_DEP_FILES   := $(DEP_FILES)
